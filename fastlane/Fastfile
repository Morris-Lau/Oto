# frozen_string_literal: true

default_platform(:ios)

def internal_pilot_opts(key)
  groups = (ENV["TESTFLIGHT_GROUPS"] || "").split(",").map(&:strip).reject(&:empty?)
  opts = {
    skip_waiting_for_build_processing: false,
    skip_submission: true,
    distribute_external: false,
    notify_external_testers: false
  }
  opts[:groups] = groups unless groups.empty?
  opts[:api_key] = key if key
  opts
end

def asc_api_key
  return unless ENV["APP_STORE_CONNECT_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"]

  if ENV["APP_STORE_CONNECT_KEY_CONTENT"]
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true
    )
  elsif ENV["APP_STORE_CONNECT_KEY_PATH"]
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: File.expand_path(ENV.fetch("APP_STORE_CONNECT_KEY_PATH"))
    )
  end
end

platform :ios do
  desc "Build Release IPA and upload to TestFlight via pilot"
  lane :beta do
    key = asc_api_key
    app_id = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    UI.user_error!("app_identifier not set (Appfile or APP_IDENTIFIER env var)") if app_id.nil? || app_id.empty?

    profile_name = nil
    if key
      sigh(app_identifier: app_id, force: true, api_key: key)
      profile_name = lane_context[SharedValues::SIGH_NAME]
    end

    export_opts = { method: "app-store", uploadSymbols: true }
    if profile_name
      export_opts[:signingStyle] = "manual"
      export_opts[:provisioningProfiles] = { app_id => profile_name }
    else
      export_opts[:signingStyle] = "automatic"
    end

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    UI.message("Using build number #{build_number}")

    gym(
      project: "Oto.xcodeproj",
      scheme: "Oto",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Oto.ipa",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: export_opts
    )

    pilot_opts = internal_pilot_opts(key)
    pilot(pilot_opts)
  end

  desc "Upload an existing IPA (IPA_PATH=/abs/or/rel/path/Oto.ipa); defaults to newest build/*.ipa"
  lane :upload_testflight do
    key = asc_api_key
    ipa =
      if ENV["IPA_PATH"]
        File.expand_path(ENV["IPA_PATH"])
      else
        Dir["build/*.ipa"].max_by { |p| File.mtime(p) }
      end
    UI.user_error!("No IPA found. Set IPA_PATH or add build/*.ipa") unless ipa && File.exist?(ipa)

    pilot_opts = internal_pilot_opts(key).merge(ipa: ipa)
    pilot(pilot_opts)
  end
end
